{
  "name": "arxiv-service",
  "version": "0.1.0",
  "description": "Standalone arXiv paper translation + compilation service",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "server": "node src/server.js",
    "dev": "vite --host 127.0.0.1",
    "dev:api": "node --watch src/server.js",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis portable",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --host 127.0.0.1"
  },
  "main": "main.js",
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^4.21.0",
    "lucide-react": "^1.14.0",
    "multer": "^1.4.5-lts.1",
    "next-themes": "^0.4.6",
    "pako": "^2.1.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "tar": "^7.4.0",
    "undici": "^7.25.0",
    "vite": "^8.0.11"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "com.fanrj3.arxivtranslate",
    "productName": "arXiv Translate",
    "directories": {
      "output": "release"
    },
    "asar": false,
    "files": [
      "main.js",
      "package.json",
      "dist/**/*",
      "src/**/*",
      "deepseek_v3_tokenizer/**/*",
      "!jobs/**/*",
      "!release/**/*",
      "!settings.json",
      "!server*.log"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
